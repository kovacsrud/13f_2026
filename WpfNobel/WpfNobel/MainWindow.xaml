<Window x:Class="WpfNobel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfNobel"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="datagridNobel" ColumnWidth="*"/>

        <WrapPanel VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1">
            <Button x:Name="buttonBetoltes" Width="100" Height="30" Content="Betöltés" Click="buttonBetoltes_Click"/>
            <TextBox x:Name="textboxKeresztnev" Width="200" Height="30" FontSize="18" Margin="10,0,0,0"/>
            <Button x:Name="buttonKereses" Width="100" Height="30" Content="Keresés" Margin="10,0,0,0" Click="buttonKereses_Click"/>
            <Button x:Name="buttonVissza" Width="100" Height="30" Content="Vissza" Margin="10,0,0,0" Click="buttonVissza_Click"/>
            <ComboBox x:Name="comboTipus" Width="100" Margin="10,0,0,0" SelectionChanged="comboTipus_SelectionChanged"/>
        </WrapPanel>
        <Button x:Name="buttonMentes" Width="100" Height="30" Content="Mentés fájlba" Grid.Row="2" Click="buttonMentes_Click"/>

    </Grid>
</Window>
