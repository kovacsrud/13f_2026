<Window x:Class="WpfSzamolas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfSzamolas"
        mc:Ignorable="d"
        Title="Számítás" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Label Content="Szám1:" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
        <Label Content="Szám2:" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Grid.Row="1"/>
        <Label Content="Szám3:" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Grid.Row="2"/>
        <TextBox x:Name="textboxSzam1" Grid.Column="1" Width="300" Height="30" FontSize="20"/>
        <TextBox x:Name="textboxSzam2" Grid.Column="1" Grid.Row="1" Width="300" Height="30" FontSize="20"/>
        <TextBox x:Name="textboxSzam3" Grid.Column="1" Grid.Row="2" Width="300" Height="30" FontSize="20"/>

        <Label x:Name="labelEredmeny" Content=""  VerticalAlignment="Center" HorizontalAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Grid.Row="3" Grid.ColumnSpan="2" Width="400"/>
        
        <Button x:Name="buttonSzamol" Content="Számolás!" Grid.Row="4" Grid.ColumnSpan="2" Width="200"  Height="30" Click="buttonSzamol_Click"/>


    </Grid>
</Window>
