<Window x:Class="WpfHomersekletAtszamito.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHomersekletAtszamito"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Hőmérséklet:" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
        <TextBox x:Name="textboxHomerseklet" FontSize="20" Width="300" Height="30" Grid.Column="1" />
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <RadioButton x:Name="radioCelsius" Content="Konvertálás Celsiusra" FontSize="20" VerticalContentAlignment="Center" IsChecked="True" />
            <RadioButton x:Name="radioFahrenheit" Content="Konvertálás fahrenheitre" FontSize="20" VerticalContentAlignment="Center" />

        </StackPanel>
        <TextBlock Text="Eredmény:" Grid.Row="2" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
        <TextBlock x:Name="textblockEredmeny" Text="" Grid.Row="2" Grid.Column="1" Width="300" Height="30" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
        <Button x:Name="buttonSzamol" Content="Számolás" Grid.Row="3" Grid.ColumnSpan="2" Width="200" Height="30" Click="buttonSzamol_Click"/>


    </Grid>
</Window>
