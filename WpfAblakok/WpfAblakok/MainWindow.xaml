<Window x:Class="WpfAblakok.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAblakok"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl FontSize="16">
            <TabItem Header="Adat1" >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="TabControl" FontSize="30"  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Text="TabControl" FontSize="30" Grid.Row="1" Grid.Column="1"  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Text="TabControl" FontSize="30" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center"  VerticalAlignment="Center" />

                </Grid>
            </TabItem>
            <TabItem Header="Adat2" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="30" Text="Textblock" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBox Width="300" Height="30" Grid.Row="1"/>

                </Grid>

            </TabItem>
        </TabControl>
    </Grid>
</Window>
